# Host Ollama. From inside containers the host is reached via host.docker.internal.
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLAMA_MODEL=llama3.1:8b

# Coordinator refine loop: max Synthesizer<->Critic revisions before giving up.
MAX_REVISIONS=2

# arXiv MCP endpoint (streamable-http). Used by the researcher.
MCP_ARXIV_URL=http://mcp_arxiv:8000/mcp
